require_relative '../ReactNativeModule/node_modules/react-native/scripts/react_native_pods'

node_modules_path = File.expand_path('../ReactNativeModule/node_modules', __dir__)
ENV['REACT_NATIVE_NODE_MODULES_DIR'] = node_modules_path

# Symlink node_modules into Expenso/ so Node can resolve react-native from here
local_node_modules = File.join(__dir__, 'node_modules')
unless File.exist?(local_node_modules)
  File.symlink('../ReactNativeModule/node_modules', local_node_modules)
end

# Workaround for fmt consteval errors with Xcode 26+ Clang.
# Patch the fmt podspec before CocoaPods resolves dependencies,
# so the compiler flags are baked into the generated xcconfig files.
fmt_podspec_path = File.expand_path('../ReactNativeModule/node_modules/react-native/third-party-podspecs/fmt.podspec', __dir__)
if File.exist?(fmt_podspec_path)
  fmt_content = File.read(fmt_podspec_path)
  unless fmt_content.include?('FMT_CONSTEVAL')
    patched = fmt_content.gsub(
      'spec.source_files = ["include/fmt/*.h", "src/format.cc"]',
      "spec.compiler_flags = '-DFMT_USE_CONSTEVAL=0 -DFMT_CONSTEVAL=constexpr'\n  spec.source_files = [\"include/fmt/*.h\", \"src/format.cc\"]"
    )
    File.write(fmt_podspec_path, patched)
  end
end

platform :ios, '16.0'
prepare_react_native_project!

target 'Expenso' do
  use_react_native!(
    :path => '../ReactNativeModule/node_modules/react-native',
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => true
  )

  pod 'RNReanimated', :path => '../ReactNativeModule/node_modules/react-native-reanimated'
  pod 'RNGestureHandler', :path => '../ReactNativeModule/node_modules/react-native-gesture-handler'
  pod 'RNSVG', :path => '../ReactNativeModule/node_modules/react-native-svg'

  post_install do |installer|
    react_native_post_install(
      installer,
      '../ReactNativeModule/node_modules/react-native',
      :mac_catalyst_enabled => false
    )
  end
end
